      <sparkle:version>81</sparkle:version>
      <sparkle:shortVersionString>1.8.1</sparkle:shortVersionString>
      <sparkle:minimumSystemVersion>15.0</sparkle:minimumSystemVersion>
      <description><![CDATA[Browsing from another machine now covers everything: sites that preferred your direct connection (like YouTube) follow the place you picked too. Everything returns to normal the moment you switch back.]]></description>
      <enclosure url="https://github.com/thecloudstation/connect-releases/releases/download/v1.8.1/CloudStationConnect-1.8.1.zip"
