    </item>
    <item>
      <title>1.4.0</title>
      <pubDate>Tue, 21 Jul 2026 15:06:20 +0000</pubDate>
      <sparkle:version>65</sparkle:version>
      <sparkle:shortVersionString>1.4.0</sparkle:shortVersionString>
      <sparkle:minimumSystemVersion>15.0</sparkle:minimumSystemVersion>
      <description><![CDATA[File drop: send files between your devices over the mesh. Drag a file from Finder onto any online Mac or Linux server in the CloudStation Connect window and it transfers directly, peer-to-peer and end-to-end encrypted, resuming automatically if interrupted. Received files land in ~/Downloads/CloudStation Received. On Linux, files arrive in the agent inbox and can be sent with csmesh-agent send.]]></description>
      <enclosure url="https://github.com/thecloudstation/connect-releases/releases/download/v1.4.0/CloudStationConnect-1.4.0.zip"
                 length="31705187"
                 type="application/octet-stream"
                 sparkle:edSignature="YoW2C7SaBJqR+Kc2VY3ONkCXgwzSD+M1pts93NP69wkGOCjJed97tfWNF2ecIn/SUwiAurNxvFnE0+oBWO5wBg=="/>
    </item>
    <item>
      <title>1.3.0</title>
      <pubDate>Sun, 19 Jul 2026 18:16:04 +0000</pubDate>
      <sparkle:version>53</sparkle:version>
      <sparkle:shortVersionString>1.3.0</sparkle:shortVersionString>
      <sparkle:minimumSystemVersion>15.0</sparkle:minimumSystemVersion>
      <description><![CDATA[Sharing can now include the networks behind a device. When you share a device that routes subnets (a jumpbox or gateway), the share sheet offers 'Networks behind this device' — the person's devices then reach those networks directly, no tunnels needed. Access to the network itself is now restricted to administrator accounts.]]></description>
      <enclosure url="https://github.com/thecloudstation/connect-releases/releases/download/v1.3.0/CloudStationConnect-1.3.0.zip"
                 length="31443212"
                 type="application/octet-stream"
                 sparkle:edSignature="pyWgZTyHLjuZAJ8Kt/XyXulB4yKVQ4esOIxqopOIddsI01G9Iiz0vDCEQN8seHDMgKV4sshD8JWXDKvZf61jBQ=="/>
    </item>
    <item>
      <title>1.2.0</title>
      <pubDate>Sat, 18 Jul 2026 09:06:53 +0000</pubDate>
      <sparkle:version>48</sparkle:version>
      <sparkle:shortVersionString>1.2.0</sparkle:shortVersionString>
      <sparkle:minimumSystemVersion>15.0</sparkle:minimumSystemVersion>
      <description><![CDATA[Add a device can now join a Linux server over SSH: pick Linux server, enter user@host and the password, and the app installs the agent and connects the machine to your network. Linux boxes can also join with a one-line install command using any device code.]]></description>
      <enclosure url="https://github.com/thecloudstation/connect-releases/releases/download/v1.2.0/CloudStationConnect-1.2.0.zip"
                 length="31434892"
                 type="application/octet-stream"
