    <item>
      <title>1.10.3</title>
      <pubDate>Fri, 24 Jul 2026 12:58:16 +0000</pubDate>
      <sparkle:version>121</sparkle:version>
      <sparkle:shortVersionString>1.10.3</sparkle:shortVersionString>
      <sparkle:minimumSystemVersion>15.0</sparkle:minimumSystemVersion>
      <description><![CDATA[More network resilience fixes: if 'Browse from' is interrupted, your place now switches back on automatically once the connection recovers (previously it could get stuck off). Includes the earlier auto-recovery and network-change reconnection improvements.]]></description>
      <enclosure url="https://github.com/thecloudstation/connect-releases/releases/download/v1.10.3/CloudStationConnect-1.10.3.zip"
                 length="32029612"
                 type="application/octet-stream"
                 sparkle:edSignature="WELbWAS1FxIKUCvuXt4Nsb2bKWn5pwfiV90P/dIzUeKosC4SbRXOk3wGjT2nxmntTe+GEjbg5+iXUbRgZpZQCQ=="/>
    </item>
    <item>
      <title>1.10.2</title>
      <pubDate>Fri, 24 Jul 2026 11:56:45 +0000</pubDate>
      <sparkle:version>119</sparkle:version>
      <sparkle:shortVersionString>1.10.2</sparkle:shortVersionString>
      <sparkle:minimumSystemVersion>15.0</sparkle:minimumSystemVersion>
      <description><![CDATA[Fixes for network resilience: a broken 'Browse from' place no longer takes your internet down (auto-recovers within a minute); the mesh reconnects itself when your Mac changes networks; exit machines running Docker now forward traffic correctly.]]></description>
      <enclosure url="https://github.com/thecloudstation/connect-releases/releases/download/v1.10.2/CloudStationConnect-1.10.2.zip"
                 length="32028626"
                 type="application/octet-stream"
                 sparkle:edSignature="ZCcXJpnf+/ramn+FptWQnSclH5vtxhL1b2+YP83/Z9KlACtV/j2wHn8SRHVVX/2f2g83TFP1TFldfIEPypWqDg=="/>
    </item>
    <item>
      <title>1.10.1</title>
      <pubDate>Thu, 23 Jul 2026 13:50:17 +0000</pubDate>
      <sparkle:version>112</sparkle:version>
      <sparkle:shortVersionString>1.10.1</sparkle:shortVersionString>
      <sparkle:minimumSystemVersion>15.0</sparkle:minimumSystemVersion>
      <description><![CDATA[Settings can check for updates again: version and build, when the feed was last checked, a Check for Updates button, and a relaunch-to-install row when an update is waiting.]]></description>
      <enclosure url="https://github.com/thecloudstation/connect-releases/releases/download/v1.10.1/CloudStationConnect-1.10.1.zip"
                 length="32024596"
                 type="application/octet-stream"
                 sparkle:edSignature="0bzYPqQ0GbBoWIyf/00dqdJ4AcFy87U5tQ0PGjeuYiiVDJ0mjSuxd+PrzF2HLZzOKu4d+aVhLRQVIy4plratAQ=="/>
    </item>
    <item>
      <title>1.10.0</title>
      <pubDate>Thu, 23 Jul 2026 13:40:19 +0000</pubDate>
      <sparkle:version>111</sparkle:version>
      <sparkle:shortVersionString>1.10.0</sparkle:shortVersionString>
      <sparkle:minimumSystemVersion>15.0</sparkle:minimumSystemVersion>
      <description><![CDATA[Gateways can now advertise the networks behind them right from device detail (admins). Devices that can't carry your traffic can no longer be offered or picked as places. A machine with a broken exit now recovers to direct on its own instead of losing its connection. File drop only lights up devices that can actually receive, and tells you exactly what to ask for when they can't. The window shows a banner when your network can't be reached instead of devices silently going offline. The share sheet now says why Share is disabled.]]></description>
      <enclosure url="https://github.com/thecloudstation/connect-releases/releases/download/v1.10.0/CloudStationConnect-1.10.0.zip"
                 length="32015462"
                 type="application/octet-stream"
                 sparkle:edSignature="xhnRRHGwegw0qVkVDH4CMgOkmb0x6jOhFb2OciXlMZyLJhb+ioovh4Va0Ubc3XUb0AacRdRJ0knaprcLAlkSDQ=="/>
    </item>
